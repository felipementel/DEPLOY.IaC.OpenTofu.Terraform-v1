.internal/

########################
#   TERRAFORM
#########################

# Terraform ignore
.env*

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# ⚠️ IMPORTANTE: Credenciais
credentials.auto.tfvars
*credentials*.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock file (opcional - depende da sua estratégia)
.terraform.lock.hcl
